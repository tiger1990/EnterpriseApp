        android:fillColor="#FF000000"
        android:pathData="
            M57,47.5
            L57.8,43
            L57,42.5
            L56.2,43
            Z" />

    <!-- ═══════════════════════════════════════════════
         STUPA / PAGODA (bottom right, simplified)
    ═══════════════════════════════════════════════ -->
    <!-- Base tier -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M76,82 L80,82 L80,79 L76,79 Z" />
    <!-- Middle tier -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M75,79 L81,79 L81,76 L75,76 Z" />
    <!-- Upper tier -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M76,76 L80,76 L80,74 L76,74 Z" />
    <!-- Spire -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M78,74 L79,69 L78,68 L77,69 Z" />

