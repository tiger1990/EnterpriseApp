            Z" />

    <!-- Cardinal letters N, S, E, W (text as paths for vector purity) -->
    <!-- W letter (left, ~x=25) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M23,51 L25,57 L27,53 L29,57 L31,51
            L30,51 L29,55 L27,51.5 L25,55 L24,51 Z" />

    <!-- E letter (right, ~x=77) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M77,51 L77,57 L83,57 L83,56 L78,56 L78,54.5 L82,54.5 L82,53.5 L78,53.5 L78,52 L83,52 L83,51 Z" />

</vector>
