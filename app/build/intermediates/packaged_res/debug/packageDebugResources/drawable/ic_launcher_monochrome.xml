<?xml version="1.0" encoding="utf-8"?>
<!--
    Travel Monk - Monochrome Adaptive Icon Layer
    Use this as the android:monochrome attribute in your adaptive icon XML.
    Android 13+ will tint this with the user's Material You wallpaper color.

    viewportWidth/Height = 108dp (standard adaptive icon canvas)
    Safe zone = center 72dp (18dp padding on each side)
    The design is intentionally flat/silhouette for clean themed icon rendering.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ═══════════════════════════════════════════════
         COMPASS ROSE - 4-pointed star shape
         Center: (54, 54), safe zone fits within 18–90
    ═══════════════════════════════════════════════ -->

    <!-- North spike (tall) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M54,20
            L58,50
            L54,54
            L50,50
            Z" />

    <!-- South spike (shorter) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M54,88
            L58,58
            L54,54
            L50,58
            Z" />

    <!-- East spike -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M88,54
            L58,50
            L54,54
            L58,58
            Z" />

    <!-- West spike -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M20,54
            L50,50
            L54,54
            L50,58
            Z" />

    <!-- ═══════════════════════════════════════════════
         OUTER RING (donut) — compass bezel
         Outer radius ~31, inner radius ~27
    ═══════════════════════════════════════════════ -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M54,23
            A31,31 0 1,1 53.99,23
            Z
            M54,27
            A27,27 0 1,0 54.01,27
            Z"
        android:fillType="evenOdd" />

    <!-- ═══════════════════════════════════════════════
         MONK HEAD SILHOUETTE
         Bald head profile facing right, centered in compass
    ═══════════════════════════════════════════════ -->
    <!-- Head (oval, slightly right-shifted inside compass) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M54,36
            C60,36 65,41 65,48
            C65,55 61,60 56,62
            C54,63 52,63 50,62
            C45,60 42,55 42,48
            C42,41 47,36 54,36
            Z" />

    <!-- Neck -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M49,62
            L50,68
            L58,68
            L59,62
            C57,63 55,63.5 53,63
            Z" />

    <!-- Shoulders / robe hint -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M44,68
            C41,70 39,73 39,76
            L69,76
            C69,73 67,70 64,68
            L58,68
            L50,68
            Z" />

    <!-- ═══════════════════════════════════════════════
         SMALL COMPASS on forehead (circle + crosshairs)
    ═══════════════════════════════════════════════ -->
    <!-- Compass circle on head -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M57,43
            A5,5 0 1,1 56.99,43
            Z
            M57,45
            A3,3 0 1,0 57.01,45
            Z"
        android:fillType="evenOdd" />

    <!-- N pointer inside mini compass -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M57,38.5
            L57.8,43
            L57,43.5
            L56.2,43
            Z" />

    <!-- S pointer -->
